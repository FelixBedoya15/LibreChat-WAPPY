<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - WAPPY IA</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #0f172a;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      color: #e2e8f0;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      width: 100%;
      background-color: #0f172a;
      padding: 40px 0;
    }
    .main-table {
      max-width: 550px;
      margin: 0 auto;
      border-collapse: collapse;
    }
    .header-logo {
      padding: 20px 0 30px 0;
      text-align: center;
    }
    .logo-img {
      max-height: 48px;
      width: auto;
      display: inline-block;
    }
    .card {
      background-color: #1e293b;
      border-radius: 20px;
      border: 1px solid #334155;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
      padding: 40px 35px;
      margin: 0 15px;
    }
    .title {
      font-size: 22px;
      font-weight: 700;
      color: #ffffff;
      margin-top: 0;
      margin-bottom: 20px;
      line-height: 1.3;
      text-align: left;
    }
    .content-text {
      font-size: 15px;
      line-height: 1.6;
      color: #94a3b8;
      margin-bottom: 25px;
    }
    .highlight-name {
      color: #38bdf8;
      font-weight: 600;
    }
    .notification-body {
      background-color: rgba(16, 185, 129, 0.05);
      border-left: 4px solid #10b981;
      padding: 20px;
      border-radius: 0 12px 12px 0;
      margin: 25px 0;
      color: #f1f5f9;
      font-size: 15px;
      line-height: 1.6;
    }
    .btn-container {
      text-align: center;
      margin: 30px 0 15px 0;
    }
    .btn {
      display: inline-block;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: #ffffff !important;
      text-decoration: none;
      padding: 12px 26px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }
    .footer-signature {
      border-top: 1px solid #334155;
      margin-top: 35px;
      padding-top: 25px;
      font-size: 14px;
      color: #94a3b8;
      line-height: 1.5;
    }
    .signature-team {
      color: #10b981;
      font-weight: 600;
    }
    .footer-info {
      text-align: center;
      padding: 30px 0;
      font-size: 12px;
      color: #64748b;
      line-height: 1.6;
    }
    .footer-info a {
      color: #10b981;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <table class="main-table" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td class="header-logo">
          <a href="https://wappy.club" target="_blank">
            <img class="logo-img" src="https://wappy.club/assets/logo.png" alt="WAPPY IA">
          </a>
        </td>
      </tr>
      <tr>
        <td>
          <div class="card">
            <h1 class="title">{{title}}</h1>
            <p class="content-text">Hola <span class="highlight-name">{{name}}</span>,</p>
            <p class="content-text">Tienes una nueva notificación en tu portal de WAPPY IA:</p>
            
            <div class="notification-body">
              {{body}}
            </div>
            
            <div class="btn-container">
              <a href="https://wappy.club" target="_blank" class="btn">Ir al portal</a>
            </div>
            
            <div class="footer-signature">
              Un abrazo,<br>
              <span class="signature-team">El equipo de WAPPY IA</span>
            </div>
          </div>
        </td>
      </tr>
      <tr>
        <td class="footer-info">
          <p>© {{year}} WAPPY IA. Todos los derechos reservados.</p>
          <p>
            <a href="https://wappy.club" target="_blank">Sitio Web</a> • 
            <a href="mailto:soporte@wappy.club">Soporte técnico</a>
          </p>
        </td>
      </tr>
    </table>
  </div>
</body>
</html>
